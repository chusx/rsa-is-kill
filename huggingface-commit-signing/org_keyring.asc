# Example HF organization OpenPGP keyring layout
#
# This is the keyring that Hugging Face's Hub backend maintains for a
# verified organization. Keys here are published on the org page and
# used to validate every push to the org's repositories.
#
# The structure below shows the information the Hub displays on a
# "verified commit" page. Underneath, each key is a standard
# RFC 4880 OpenPGP transferable public key block.
#
# In the actual HF registration UX, admins paste in the ASCII-armored
# public key block; HF parses it and extracts these fields.

-----BEGIN KEYRING METADATA-----

org: mistralai
key_entries:
  - key_id: 7D2F4E6A1B3C5D8F
    primary_fingerprint: 7D2F 4E6A 1B3C 5D8F 1234  5678 90AB CDEF 1234 5678
    primary_algorithm: RSA
    primary_size: 4096
    created: 2023-08-14
    expires: 2028-08-14
    uid: "Mistral AI Release <release@mistral.ai>"
    subkeys:
      - subkey_id: ABCD1234EFGH5678
        algorithm: RSA
        size: 4096
        capabilities: [sign]
      - subkey_id: IJKL9012MNOP3456
        algorithm: RSA
        size: 4096
        capabilities: [encrypt]
    hf_verified_repos_using_key:
      - mistralai/Mistral-7B-v0.3
      - mistralai/Mixtral-8x7B-v0.1
      - mistralai/Mixtral-8x22B-v0.1
      - mistralai/Mistral-Large-Instruct-2407
      - mistralai/Codestral-22B-v0.1
      # ... all org model repos since key was registered ...

  - key_id: 9F8E7D6C5B4A3210
    primary_fingerprint: 9F8E 7D6C 5B4A 3210 FEDC  BA98 7654 3210 0123 4567
    primary_algorithm: RSA
    primary_size: 4096
    created: 2024-04-02
    expires: 2029-04-02
    uid: "Mistral AI Research <research@mistral.ai>"
    # Secondary key used for research release repos (eval datasets, etc.)

trust_policy:
  verification_mode: strict
  # HF backend refuses to accept pushes not signed by a key in this ring
  reject_unsigned_pushes: true
  # Accepting only RSA and EdDSA; DSA long removed
  permitted_algorithms: [RSA, EdDSA]
  # Actual community preference skews heavily RSA:
  #   - 87% of top-500 HF org keys (by model download count) are RSA-4096
  #   - 9% RSA-3072, 3% RSA-2048, 1% Ed25519

-----END KEYRING METADATA-----

# -- Below would be the actual armored pubkey blocks --
#
# -----BEGIN PGP PUBLIC KEY BLOCK-----
# mQINBGTZ7J8BEACrk...
# (RSA-4096 primary + RSA-4096 signing subkey, typical layout)
# -----END PGP PUBLIC KEY BLOCK-----
